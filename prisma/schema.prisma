generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Entry {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  code      String   @unique
  paid      Boolean  @default(false)
  used      Boolean  @default(false)
  walkin    Boolean  @default(false)
  createdAt DateTime @default(now())
}
